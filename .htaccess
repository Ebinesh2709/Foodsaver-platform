# FoodSaver — Apache configuration
# Bare minimum for InfinityFree compatibility

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Old user-facing food browsing pages
    RewriteRule ^userBrowseFood\.html$      /browse_listings.php     [R=301,L]
    RewriteRule ^userViewFood\.html$        /browse_listings.php     [R=301,L]
    RewriteRule ^userHomePage\.html$        /index.php               [R=301,L]
    RewriteRule ^loginPage\.html$           /auth/login.php          [R=301,L]
    RewriteRule ^registerPage\.html$        /auth/register.php       [R=301,L]
    RewriteRule ^userProfile\.html$         /my_reservations.php     [R=301,L]
    RewriteRule ^userCart\.html$            /my_reservations.php     [R=301,L]
    RewriteRule ^businessDashboard\.html$   /business/dashboard.php  [R=301,L]
    RewriteRule ^businessAddFood\.html$     /business/add_listing.php [R=301,L]
    RewriteRule ^businessEditFood\.html$    /business/edit_listing.php [R=301,L]
    RewriteRule ^adminDashboard\.html$      /admin/dashboard.php     [R=301,L]
    
    # Catch-all: any remaining .html file → 404
    RewriteRule \.html$                     /404.php                 [R=301,L]
</IfModule>

# Custom error pages
ErrorDocument 404 /404.php
